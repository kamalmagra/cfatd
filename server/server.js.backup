const VALID_ATTENDANCE_SCAN_TYPES = new Set(["ENTRY", "BREAK_OUT", "BREAK_IN", "OUT"]);

const ATTENDANCE_ACTION_LABELS = {
    ENTRY: "In",
    BREAK_OUT: "Break out",
    BREAK_IN: "Break in",
    OUT: "Out",
};

const ATTENDANCE_TIME_ZONE =
    process.env.ATTENDANCE_TIME_ZONE ||
    process.env.WHATSAPP_TIME_ZONE ||
    "Europe/London";

const getAttendanceDateKey = (value = new Date()) => {
    const date = value instanceof Date ? value : new Date(value);

    if (Number.isNaN(date.getTime())) {
        return new Date().toISOString().slice(0, 10);
    }

    const parts = new Intl.DateTimeFormat("en-GB", {
        timeZone: ATTENDANCE_TIME_ZONE,
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
    }).formatToParts(date);

    const valueFor = (type) => {
        const part = parts.find((item) => item.type === type);
        return part ? part.value : "";
    };

    return `${valueFor("year")}-${valueFor("month")}-${valueFor("day")}`;
};

const buildLegacyAttendanceEvents = (attendance) => {
    const events = [];

    if (attendance.entryTime) {
        events.push({ scanType: "ENTRY", scannedAt: attendance.entryTime });
    }

    if (attendance.breakOutTime) {
        events.push({ scanType: "BREAK_OUT", scannedAt: attendance.breakOutTime });
    }

    if (attendance.breakInTime) {
        events.push({ scanType: "BREAK_IN", scannedAt: attendance.breakInTime });
    }

    if (attendance.lastOutTime) {
        events.push({ scanType: "OUT", scannedAt: attendance.lastOutTime });
    }

    return events;
};

const getAttendanceEvents = (attendance) => {
    const history = Array.isArray(attendance && attendance.scanHistory) ?
        attendance.scanHistory :
        [];

    const usableHistory = history
        .map((item) => ({
            scanType: String(item.scanType || "").trim().toUpperCase(),
            scannedAt: item.scannedAt ? new Date(item.scannedAt) : null,
        }))
        .filter(
            (item) =>
            VALID_ATTENDANCE_SCAN_TYPES.has(item.scanType) &&
            item.scannedAt &&
            !Number.isNaN(item.scannedAt.getTime())
        );

    const events = usableHistory.length > 0 ?
        usableHistory :
        buildLegacyAttendanceEvents(attendance);

    return events.sort(
        (left, right) => new Date(left.scannedAt) - new Date(right.scannedAt)
    );
};

const calculateAttendanceTimeline = (
    attendance,
    referenceTime = new Date()
) => {
    const events = getAttendanceEvents(attendance);
    const workSessions = [];
    const breakSessions = [];

    let activeSession = null;
    let activeBreak = null;
    let currentStatus = "NOT_STARTED";
    let firstEntryTime = null;
    let latestBreakOutTime = null;
    let latestBreakInTime = null;
    let latestOutTime = null;
    let entryCount = 0;

    const closeBreak = (endTime, explicitBreakIn = true) => {
        if (!activeSession || !activeBreak) return;

        const safeEnd = new Date(endTime);
        const durationSeconds = Math.max(
            0,
            Math.floor((safeEnd - activeBreak.startedAt) / 1000)
        );

        activeSession.breakSeconds += durationSeconds;

        breakSessions.push({
            breakOutTime: activeBreak.startedAt,
            breakInTime: explicitBreakIn ? safeEnd : null,
            durationSeconds,
            workSessionIndex: workSessions.length,
        });

        if (explicitBreakIn) {
            latestBreakInTime = safeEnd;
        }

        activeBreak = null;
    };

    const closeWorkSession = (outTime) => {
        if (!activeSession) return;

        const safeOut = new Date(outTime);

        if (activeBreak) {
            closeBreak(safeOut, false);
        }

        const grossSeconds = Math.max(
            0,
            Math.floor((safeOut - activeSession.entryTime) / 1000)
        );

        workSessions.push({
            entryTime: activeSession.entryTime,
            outTime: safeOut,
            totalBreakSeconds: activeSession.breakSeconds,
            totalWorkSeconds: Math.max(
                0,
                grossSeconds - activeSession.breakSeconds
            ),
        });

        activeSession = null;
        activeBreak = null;
        latestOutTime = safeOut;
        currentStatus = "OUT";
    };

    for (const event of events) {
        const eventTime = new Date(event.scannedAt);

        if (event.scanType === "ENTRY") {
            if (!activeSession) {
                entryCount += 1;
                activeSession = {
                    entryTime: eventTime,
                    breakSeconds: 0,
                };
                activeBreak = null;
                currentStatus = "WORKING";

                if (!firstEntryTime) {
                    firstEntryTime = eventTime;
                }
            }

            continue;
        }

        if (event.scanType === "BREAK_OUT") {
            if (activeSession && !activeBreak) {
                activeBreak = { startedAt: eventTime };
                latestBreakOutTime = eventTime;
                currentStatus = "ON_BREAK";
            }

            continue;
        }

        if (event.scanType === "BREAK_IN") {
            if (activeSession && activeBreak) {
                closeBreak(eventTime, true);
                currentStatus = "WORKING";
            }

            continue;
        }

        if (event.scanType === "OUT" && activeSession) {
            closeWorkSession(eventTime);
        }
    }

    if (activeSession) {
        let safeReference = referenceTime instanceof Date ?
            referenceTime :
            new Date(referenceTime);

        if (
            Number.isNaN(safeReference.getTime()) ||
            safeReference < activeSession.entryTime
        ) {
            safeReference = events.length > 0 ?
                new Date(events[events.length - 1].scannedAt) :
                activeSession.entryTime;
        }

        let currentBreakSeconds = activeSession.breakSeconds;

        if (activeBreak) {
            const runningBreakSeconds = Math.max(
                0,
                Math.floor((safeReference - activeBreak.startedAt) / 1000)
            );

            currentBreakSeconds += runningBreakSeconds;

            breakSessions.push({
                breakOutTime: activeBreak.startedAt,
                breakInTime: null,
                durationSeconds: runningBreakSeconds,
                workSessionIndex: workSessions.length,
            });
        }

        const grossSeconds = Math.max(
            0,
            Math.floor((safeReference - activeSession.entryTime) / 1000)
        );

        workSessions.push({
            entryTime: activeSession.entryTime,
            outTime: null,
            totalBreakSeconds: currentBreakSeconds,
            totalWorkSeconds: Math.max(0, grossSeconds - currentBreakSeconds),
        });

        currentStatus = activeBreak ? "ON_BREAK" : "WORKING";
    }

    const totalBreakSeconds = breakSessions.reduce(
        (sum, item) => sum + (Number(item.durationSeconds) || 0),
        0
    );

    const totalWorkSeconds = workSessions.reduce(
        (sum, item) => sum + (Number(item.totalWorkSeconds) || 0),
        0
    );

    return {
        currentStatus,
        entryTime: firstEntryTime,
        breakOutTime: latestBreakOutTime,
        breakInTime: latestBreakInTime,
        lastOutTime: latestOutTime,
        totalBreakSeconds,
        totalWorkSeconds,
        workSessions,
        breakSessions,
        workSessionCount: workSessions.length,
        completedWorkSessionCount: workSessions.filter((item) => item.outTime).length,
        breakCount: breakSessions.length,
        reentryCount: Math.max(0, entryCount - 1),
        events,
    };
};

const recalculateAttendanceFromHistory = (
    attendance,
    referenceTime = new Date()
) => {
    const timeline = calculateAttendanceTimeline(attendance, referenceTime);

    attendance.entryTime = timeline.entryTime;
    attendance.breakOutTime = timeline.breakOutTime;
    attendance.breakInTime = timeline.breakInTime;
    attendance.lastOutTime = timeline.lastOutTime;
    attendance.currentStatus = timeline.currentStatus;
    attendance.totalBreakSeconds = timeline.totalBreakSeconds;
    attendance.totalWorkSeconds = timeline.totalWorkSeconds;
    attendance.workSessions = timeline.workSessions;
    attendance.breakSessions = timeline.breakSessions;

    return timeline;
};

const attendanceStateError = (message) => {
    const error = new Error(message);
    error.statusCode = 409;
    return error;
};

const validateAttendanceAction = (attendance, scanType) => {
    const timeline = calculateAttendanceTimeline(attendance, new Date());
    const status = timeline.currentStatus;

    if (scanType === "ENTRY") {
        if (status === "WORKING") {
            throw attendanceStateError("You are already signed in.");
        }

        if (status === "ON_BREAK") {
            throw attendanceStateError(
                "Your break is active. Choose End Break before signing in again."
            );
        }
    }

    if (scanType === "BREAK_OUT" && status !== "WORKING") {
        throw attendanceStateError(
            status === "ON_BREAK" ?
            "Your break has already started." :
            "Sign in before taking a break."
        );
    }

    if (scanType === "BREAK_IN" && status !== "ON_BREAK") {
        throw attendanceStateError("No active break was found to end.");
    }

    if (
        scanType === "OUT" &&
        status !== "WORKING" &&
        status !== "ON_BREAK"
    ) {
        throw attendanceStateError(
            status === "OUT" ?
            "You have already signed out." :
            "Sign in before signing out."
        );
    }

    return timeline;
};

const generateAdminAttendanceQrVersion = () => {
    return `ADMIN-QR-${Date.now()}-${crypto.randomBytes(12).toString("hex")}`;
};

const getAdminAttendanceQr = async() => {
    let qrConfig = await AdminAttendanceQr.findOne({ key: "attendance" });

    if (qrConfig) return qrConfig;

    try {
        qrConfig = await AdminAttendanceQr.create({
            key: "attendance",
            currentQrVersion: generateAdminAttendanceQrVersion(),
            generatedBy: "System",
            generatedAt: new Date(),
        });
    } catch (error) {
        if (error && error.code === 11000) {
            qrConfig = await AdminAttendanceQr.findOne({ key: "attendance" });
        } else {
            throw error;
        }
    }

    return qrConfig;
};

const isWhatsAppIntegrationConfigured = () => {
    return Boolean(
        process.env.WHATSAPP_GROUP_WEBHOOK_URL ||
        process.env.WHATSAPP_WEBHOOK_URL ||
        (
            process.env.WHATSAPP_ACCESS_TOKEN &&
            process.env.WHATSAPP_PHONE_NUMBER_ID &&
            process.env.WHATSAPP_RECIPIENT
        )
    );
};

const formatWhatsAppTimestamp = (date = new Date()) => {
    const timeZone = process.env.WHATSAPP_TIME_ZONE || "Europe/London";
    const parts = new Intl.DateTimeFormat("en-GB", {
        timeZone,
        day: "2-digit",
        month: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
    }).formatToParts(date);

    const value = (type) => parts.find((part) => part.type === type) ? .value || "";

    return `[${value("day")}/${value("month")}, ${value("hour")}:${value("minute")}]`;
};

const buildWhatsAppAttendanceMessage = ({ employee, scanType, scannedAt }) => {
    const identity = getEmployeeIdentity(employee);
    const employeeName = identity.username !== "-" ? identity.username : identity.name;
    const action = ATTENDANCE_ACTION_LABELS[scanType] || scanType;

    return `${formatWhatsAppTimestamp(scannedAt)} ${employeeName}: ${action}`;
};

const sendWhatsAppAttendanceNotification = async({
    employee,
    scanType,
    scannedAt,
    attendance,
    source,
}) => {
    const message = buildWhatsAppAttendanceMessage({ employee, scanType, scannedAt });
    const webhookUrl = process.env.WHATSAPP_GROUP_WEBHOOK_URL || process.env.WHATSAPP_WEBHOOK_URL;

    if (webhookUrl) {
        if (typeof fetch !== "function") {
            return {
                sent: false,
                status: "failed",
                provider: "webhook",
                message,
                error: "This Node.js version does not provide fetch(). Use Node.js 18 or newer.",
            };
        }

        try {
            const headers = { "Content-Type": "application/json" };

            if (process.env.WHATSAPP_WEBHOOK_BEARER_TOKEN) {
                headers.Authorization = `Bearer ${process.env.WHATSAPP_WEBHOOK_BEARER_TOKEN}`;
            }

            const response = await fetch(webhookUrl, {
                method: "POST",
                headers,
                body: JSON.stringify({
                    message,
                    text: message,
                    event: "attendance_scan",
                    scanType,
                    action: ATTENDANCE_ACTION_LABELS[scanType] || scanType,
                    scannedAt,
                    source,
                    attendanceId: attendance ? String(attendance._id) : "",
                    employee: {
                        id: employee && employee._id ? String(employee._id) : "",
                        name: employee && (employee.name || employee.username) || "",
                        username: employee && employee.username || "",
                        email: employee && employee.email || "",
                        mobile: employee && employee.mobile || "",
                    },
                }),
            });

            const responseText = await response.text();

            if (!response.ok) {
                throw new Error(`Webhook returned ${response.status}: ${responseText.slice(0, 300)}`);
            }

            return {
                sent: true,
                status: "sent",
                provider: "webhook",
                message,
            };
        } catch (error) {
            console.error("WhatsApp group webhook error:", error.message);
            return {
                sent: false,
                status: "failed",
                provider: "webhook",
                message,
                error: error.message,
            };
        }
    }

    const accessToken = process.env.WHATSAPP_ACCESS_TOKEN;
    const phoneNumberId = process.env.WHATSAPP_PHONE_NUMBER_ID;
    const recipient = process.env.WHATSAPP_RECIPIENT;

    if (accessToken && phoneNumberId && recipient) {
        if (typeof fetch !== "function") {
            return {
                sent: false,
                status: "failed",
                provider: "cloud-api",
                message,
                error: "This Node.js version does not provide fetch(). Use Node.js 18 or newer.",
            };
        }

        try {
            const graphVersion = process.env.WHATSAPP_GRAPH_VERSION || "v23.0";
            const response = await fetch(
                `https://graph.facebook.com/${graphVersion}/${phoneNumberId}/messages`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: `Bearer ${accessToken}`,
                    },
                    body: JSON.stringify({
                        messaging_product: "whatsapp",
                        recipient_type: "individual",
                        to: recipient,
                        type: "text",
                        text: { body: message },
                    }),
                }
            );

            const result = await response.json().catch(() => ({}));

            if (!response.ok) {
                throw new Error(result ? .error ? .message || `WhatsApp API returned ${response.status}`);
            }

            return {
                sent: true,
                status: "sent",
                provider: "cloud-api",
                message,
                messageId: result ? .messages ? .[0] ? .id || "",
            };
        } catch (error) {
            console.error("WhatsApp Cloud API error:", error.message);
            return {
                sent: false,
                status: "failed",
                provider: "cloud-api",
                message,
                error: error.message,
            };
        }
    }

    return {
        sent: false,
        status: "skipped",
        provider: "not-configured",
        message,
        error: "WhatsApp integration is not configured on the server.",
    };
};

const applyAttendanceScan = async({
    employee,
    scanType,
    source,
    scannedBy,
    qrVersion,
    notifyWhatsApp = false,
    scannedAt = new Date(),
}) => {
    if (!VALID_ATTENDANCE_SCAN_TYPES.has(scanType)) {
        const error = new Error("Invalid scan type");
        error.statusCode = 400;
        throw error;
    }

    const safeScannedAt = scannedAt instanceof Date ?
        scannedAt :
        new Date(scannedAt);

    if (Number.isNaN(safeScannedAt.getTime())) {
        const error = new Error("Invalid attendance time");
        error.statusCode = 400;
        throw error;
    }

    const identity = getEmployeeIdentity(employee);
    const employeeUserId = String(employee._id);
    const today = getAttendanceDateKey(safeScannedAt);

    let attendance = await Attendance.findOne({
        userId: employeeUserId,
        date: today,
    });

    if (!attendance) {
        attendance = new Attendance({
            userId: employeeUserId,
            date: today,
            scanHistory: [],
        });
    }

    attendance.userId = employeeUserId;
    attendance.name = identity.name;
    attendance.username = identity.username;
    attendance.email = identity.email;
    attendance.mobile = identity.mobile;

    validateAttendanceAction(attendance, scanType);

    const messages = {
        ENTRY: "Entry time saved successfully",
        BREAK_OUT: "Break out time saved successfully",
        BREAK_IN: "Break in time saved successfully",
        OUT: "Out time saved successfully",
    };

    const historyEntry = {
        scanType,
        scannedAt: safeScannedAt,
        source,
        scannedBy: scannedBy ||
            identity.username ||
            identity.email ||
            employeeUserId,
        qrVersion: qrVersion || "",
        whatsappStatus: notifyWhatsApp && isWhatsAppIntegrationConfigured() ?
            "pending" :
            "skipped",
        whatsappError: notifyWhatsApp && !isWhatsAppIntegrationConfigured() ?
            "WhatsApp integration is not configured on the server." :
            "",
    };

    if (!Array.isArray(attendance.scanHistory)) {
        attendance.scanHistory = [];
    }

    attendance.scanHistory.push(historyEntry);
    const timeline = recalculateAttendanceFromHistory(
        attendance,
        safeScannedAt
    );

    await attendance.save();

    let whatsapp = {
        sent: false,
        status: "skipped",
        provider: "manual-share",
        error: "Automatic WhatsApp sending is disabled. The employee can use the Send to WhatsApp button.",
    };

    if (notifyWhatsApp) {
        whatsapp = await sendWhatsAppAttendanceNotification({
            employee,
            scanType,
            scannedAt: safeScannedAt,
            attendance,
            source,
        });

        const lastHistoryEntry =
            attendance.scanHistory[attendance.scanHistory.length - 1];

        if (lastHistoryEntry) {
            lastHistoryEntry.whatsappStatus =
                whatsapp.status || (whatsapp.sent ? "sent" : "failed");
            lastHistoryEntry.whatsappError = whatsapp.error || "";
            await attendance.save();
        }
    }

    return {
        attendance,
        timeline,
        identity,
        employeeUserId,
        message: messages[scanType] || "Attendance saved successfully",
        whatsapp,
    };
};


app.get("/api/admin/attendance-qr", verifyAdmin, async(req, res) => {
    try {
        const qrConfig = await getAdminAttendanceQr();

        res.json({
            success: true,
            data: {
                qrVersion: qrConfig.currentQrVersion,
                generatedBy: qrConfig.generatedBy,
                generatedAt: qrConfig.generatedAt,
                qrPayload: JSON.stringify({ a: "CF", v: qrConfig.currentQrVersion }),
                whatsappEnabled: isWhatsAppIntegrationConfigured(),
            },
        });
    } catch (error) {
        console.error("Fetch admin attendance QR error:", error);
        res.status(500).json({
            success: false,
            message: "Failed to load admin attendance QR",
            error: error.message,
        });
    }
});

app.post("/api/admin/attendance-qr/regenerate", verifyAdmin, async(req, res) => {
    try {
        const newQrVersion = generateAdminAttendanceQrVersion();
        const generatedAt = new Date();

        const qrConfig = await AdminAttendanceQr.findOneAndUpdate({ key: "attendance" }, {
            $set: {
                currentQrVersion: newQrVersion,
                generatedBy: req.admin.username || "Admin",
                generatedAt,
            },
            $setOnInsert: { key: "attendance" },
        }, { new: true, upsert: true, setDefaultsOnInsert: true });

        await createAuditLog(req, {
            category: "Attendance",
            action: "REGENERATE_ADMIN_ATTENDANCE_QR",
            description: "Generated a new admin attendance QR. The previous QR is now disabled.",
            targetType: "AdminAttendanceQr",
            targetId: qrConfig._id,
            targetName: "Employee Self Scan QR",
            metadata: { generatedAt },
        });

        emitRealtimeToAdmins("adminAttendanceQrRegenerated", {
            message: "Admin attendance QR regenerated",
            generatedBy: qrConfig.generatedBy,
            generatedAt: qrConfig.generatedAt,
        });

        res.json({
            success: true,
            message: "New admin QR generated successfully. The old QR will no longer work.",
            data: {
                qrVersion: qrConfig.currentQrVersion,
                generatedBy: qrConfig.generatedBy,
                generatedAt: qrConfig.generatedAt,
                qrPayload: JSON.stringify({ a: "CF", v: qrConfig.currentQrVersion }),
                whatsappEnabled: isWhatsAppIntegrationConfigured(),
            },
        });
    } catch (error) {
        console.error("Regenerate admin attendance QR error:", error);
        res.status(500).json({
            success: false,
            message: "Failed to generate a new admin attendance QR",
            error: error.message,
        });
    }
});

app.post("/api/my/scan-admin-qr", verifyToken, async(req, res) => {
    try {
        const scanType = String(req.body.scanType || "").trim().toUpperCase();
        const qrVersion = String(req.body.qrVersion || "").trim();

        if (!VALID_ATTENDANCE_SCAN_TYPES.has(scanType) || !qrVersion) {
            return res.status(400).json({
                success: false,
                message: "Choose an attendance action and scan a valid admin QR.",
            });
        }

        const qrConfig = await getAdminAttendanceQr();

        if (qrConfig.currentQrVersion !== qrVersion) {
            return res.status(400).json({
                success: false,
                message: "This admin QR is old. Please scan the latest QR shown by admin.",
            });
        }

        const employee = await User.findById(req.user.id).select(
            "_id username email mobile currentQrVersion"
        );

        if (!employee) {
            return res.status(404).json({
                success: false,
                message: "Employee not found. Please login again.",
            });
        }

        const requestedAt = new Date();
        const today = getAttendanceDateKey(requestedAt);

        if (scanType === "ENTRY") {
            const existingAttendance = await Attendance.findOne({
                userId: String(employee._id),
                date: today,
            });

            if (existingAttendance) {
                const timeline = calculateAttendanceTimeline(
                    existingAttendance,
                    requestedAt
                );

                if (timeline.currentStatus === "OUT") {
                    let request = await AttendanceReentryRequest.findOne({
                        employeeId: employee._id,
                        date: today,
                        status: "pending",
                    }).sort({ createdAt: -1 });

                    if (!request) {
                        const identity = getEmployeeIdentity(employee);

                        request = await AttendanceReentryRequest.create({
                            employeeId: employee._id,
                            attendanceId: existingAttendance._id,
                            employeeName: identity.name,
                            employeeUsername: identity.username,
                            employeeEmail: identity.email,
                            employeeMobile: identity.mobile,
                            date: today,
                            requestedAt,
                            qrVersion,
                            status: "pending",
                        });

                        emitRealtimeToAdmins("reentryRequestCreated", {
                            message: `${identity.username || identity.name || "Employee"} requested re-entry`,
                            request,
                            createdAt: new Date(),
                        });

                        await createAuditLog(req, {
                            category: "Attendance",
                            action: "REENTRY_REQUESTED",
                            adminUsername: employee.username ||
                                employee.email ||
                                "Employee",
                            description: `${identity.username || identity.name || identity.email} requested another In after signing out on ${today}`,
                            targetType: "AttendanceReentryRequest",
                            targetId: request._id,
                            targetName: identity.username ||
                                identity.name ||
                                identity.email,
                            metadata: {
                                employeeId: String(employee._id),
                                attendanceId: String(existingAttendance._id),
                                date: today,
                                requestedAt,
                            },
                        });
                    }

                    return res.status(202).json({
                        success: true,
                        approvalRequired: true,
                        message: "You already signed out today. Re-entry request sent to admin for approval.",
                        data: existingAttendance,
                        request: {
                            _id: request._id,
                            status: request.status,
                            requestedAt: request.requestedAt,
                            date: request.date,
                        },
                    });
                }
            }
        }

        const result = await applyAttendanceScan({
            employee,
            scanType,
            source: "EMPLOYEE_ADMIN_QR",
            scannedBy: employee.username ||
                employee.email ||
                String(employee._id),
            qrVersion,
            notifyWhatsApp: false,
            scannedAt: requestedAt,
        });

        emitRealtimeToAdmins("attendanceUpdated", {
            message: result.message,
            attendance: result.attendance,
            username: result.attendance.username ||
                result.identity.username ||
                "-",
            scanType,
            source: "EMPLOYEE_ADMIN_QR",
            whatsapp: result.whatsapp,
            createdAt: new Date(),
        });

        emitRealtimeToEmployee(
            [
                result.attendance.userId,
                result.attendance.email,
                result.attendance.username,
            ],
            "myAttendanceUpdated", {
                message: result.message,
                attendance: result.attendance,
                scanType,
                source: "EMPLOYEE_ADMIN_QR",
                whatsapp: result.whatsapp,
                createdAt: new Date(),
            }
        );

        await createAuditLog(req, {
            category: "Attendance",
            action: `EMPLOYEE_SCAN_${scanType}`,
            adminUsername: employee.username || employee.email || "Employee",
            description: `${result.message} by employee self scan for ${
                result.identity.username ||
                result.identity.name ||
                result.identity.email ||
                result.employeeUserId
            }`,
            targetType: "Attendance",
            targetId: result.attendance._id,
            targetName: result.identity.username ||
                result.identity.name ||
                result.identity.email ||
                result.employeeUserId,
            metadata: {
                scanType,
                userId: result.employeeUserId,
                date: result.attendance.date,
                source: "EMPLOYEE_ADMIN_QR",
                currentStatus: result.timeline.currentStatus,
                workSessionCount: result.timeline.workSessionCount,
                breakCount: result.timeline.breakCount,
            },
        });

        res.status(201).json({
            success: true,
            message: result.message,
            username: result.attendance.username || result.identity.username,
            data: result.attendance,
            whatsapp: result.whatsapp,
        });
    } catch (error) {
        console.error("Employee admin QR scan error:", error);
        res.status(error.statusCode || 500).json({
            success: false,
            message: error.statusCode ?
                error.message :
                "Failed to save attendance",
            error: error.message,
        });
    }
});


app.get("/api/my/reentry-request/today", verifyToken, async(req, res) => {
    try {
        const today = getAttendanceDateKey(new Date());
        const request = await AttendanceReentryRequest.findOne({
            employeeId: req.user.id,
            date: today,
        }).sort({ createdAt: -1 });

        res.json({
            success: true,
            data: request || null,
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: "Failed to load re-entry request status",
            error: error.message,
        });
    }
});

app.get("/api/admin/reentry-requests", verifyAdmin, async(req, res) => {
    try {
        const requestedStatus = String(req.query.status || "pending")
            .trim()
            .toLowerCase();

        const filter = {};

        if (["pending", "approved", "denied"].includes(requestedStatus)) {
            filter.status = requestedStatus;
        }

        const requests = await AttendanceReentryRequest.find(filter)
            .sort({ requestedAt: -1 })
            .limit(200);

        res.json({
            success: true,
            data: requests,
            pendingCount: await AttendanceReentryRequest.countDocuments({
                status: "pending",
            }),
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: "Failed to load re-entry requests",
            error: error.message,
        });
    }
});

app.post(
        "/api/admin/reentry-requests/:id/decision",
        verifyAdmin,
        async(req, res) => {
            try {
                const decision = String(req.body.decision || "")
                    .trim()
                    .toLowerCase();
                const decisionNote = String(req.body.note || "").trim();

                if (!["approved", "denied"].includes(decision)) {
                    return res.status(400).json({
                        success: false,
                        message: "Decision must be approved or denied.",
                    });
                }

                const request = await AttendanceReentryRequest.findById(
                    req.params.id
                );

                if (!request) {
                    return res.status(404).json({
                        success: false,
                        message: "Re-entry request not found.",
                    });
                }

                if (request.status !== "pending") {
                    return res.status(409).json({
                        success: false,
                        message: `This request is already ${request.status}.`,
                    });
                }

                const employee = await User.findById(request.employeeId).select(
                    "_id username email mobile currentQrVersion"
                );

                if (!employee) {
                    return res.status(404).json({
                        success: false,
                        message: "Employee not found.",
                    });
                }

                let attendance = await Attendance.findById(
                    request.attendanceId
                );
                let attendanceResult = null;

                if (decision === "approved") {
                    if (!attendance) {
                        return res.status(404).json({
                            success: false,
                            message: "Attendance record not found.",
                        });
                    }

                    const timeline = calculateAttendanceTimeline(
                        attendance,
                        new Date()
                    );

                    if (timeline.currentStatus !== "OUT") {
                        request.status = "denied";
                        request.decidedAt = new Date();
                        request.decidedBy =
                            req.admin.username || "Admin";
                        request.decisionNote =
                            "Automatically closed because the employee attendance state changed.";
                        await request.save();

                        return res.status(409).json({
                            success: false,
                            message: "This request is no longer valid because the employee is not signed out.",
                        });
                    }

                    attendanceResult = await applyAttendanceScan({
                        employee,
                        scanType: "ENTRY",
                        source: "ADMIN_REENTRY_APPROVAL",
                        scannedBy: req.admin.username || "Admin",
                        qrVersion: request.qrVersion || "",
                        notifyWhatsApp: false,
                        scannedAt: request.requestedAt,
                    });

                    attendance = attendanceResult.attendance;
                }

                request.status = decision;
                request.decidedAt = new Date();
                request.decidedBy = req.admin.username || "Admin";
                request.decisionNote = decisionNote;
                await request.save();

                const approved = decision === "approved";
                const title = approved ?
                    "Re-entry approved" :
                    "Re-entry denied";
                const message = approved ?
                    `Your re-entry request for ${request.date} was approved. Your In time has been added to the same day's shift.` :
                    `Your re-entry request for ${request.date} was denied by admin.${
                      decisionNote ? ` Reason: ${decisionNote}` : ""
                  }`;

            const employeeNotification =
                await PersonalNotification.create({
                    employeeId: employee._id,
                    employeeName:
                        employee.username || employee.email || "Employee",
                    employeeUsername: employee.username || "-",
                    employeeEmail: employee.email || "-",
                    title,
                    message,
                    priority: approved ? "important" : "urgent",
                    sendEmail: false,
                    showPopup: true,
                    createdBy: req.admin.username || "Admin",
                });

            emitRealtimeToEmployee(
                [employee._id, employee.email, employee.username],
                "reentryRequestDecided",
                {
                    message,
                    request,
                    attendance,
                    notification: employeeNotification,
                    createdAt: new Date(),
                }
            );

            emitRealtimeToAdmins("reentryRequestDecided", {
                message: `${request.employeeUsername || request.employeeName} re-entry ${decision}`,
                request,
                attendance,
                createdAt: new Date(),
            });

            if (approved && attendanceResult) {
                emitRealtimeToAdmins("attendanceUpdated", {
                    message: attendanceResult.message,
                    attendance,
                    username:
                        attendance.username ||
                        attendance.name ||
                        attendance.email ||
                        "-",
                    scanType: "ENTRY",
                    source: "ADMIN_REENTRY_APPROVAL",
                    createdAt: new Date(),
                });
            }

            await createAuditLog(req, {
                category: "Attendance",
                action: approved
                    ? "REENTRY_APPROVED"
                    : "REENTRY_DENIED",
                description: `${request.employeeUsername || request.employeeName || request.employeeEmail} re-entry request was ${decision}`,
                targetType: "AttendanceReentryRequest",
                targetId: request._id,
                targetName:
                    request.employeeUsername ||
                    request.employeeName ||
                    request.employeeEmail,
                metadata: {
                    employeeId: String(request.employeeId),
                    attendanceId: String(request.attendanceId),
                    date: request.date,
                    requestedAt: request.requestedAt,
                    decidedAt: request.decidedAt,
                    decisionNote,
                },
            });

            res.json({
                success: true,
                message,
                data: {
                    request,
                    attendance,
                },
            });
        } catch (error) {
            console.error("Re-entry decision error:", error);
            res.status(error.statusCode || 500).json({
                success: false,
                message:
                    error.statusCode
                        ? error.message
                        : "Failed to process re-entry request",
                error: error.message,
            });
        }
    }
);


app.post("/api/scan/attendance", verifyAdmin, async(req, res) => {
    try {
        const { userId, qrVersion } = req.body;
        const scanType = String(req.body.scanType || "").trim().toUpperCase();

        if (!userId || !VALID_ATTENDANCE_SCAN_TYPES.has(scanType) || !qrVersion) {
            return res.status(400).json({
                success: false,
                message: "Invalid QR data",
            });
        }

        const qrUser = await findUserByIdentifier(userId);

        if (!qrUser) {
            return res.status(400).json({
                success: false,
                message: "User not found",
            });
        }

        if (!qrUser.currentQrVersion) {
            qrUser.currentQrVersion = qrVersion;
            await qrUser.save();
        }

        if (qrUser.currentQrVersion !== qrVersion) {
            return res.status(400).json({
                success: false,
                message: "This QR is old. Please generate a new QR.",
            });
        }

        const result = await applyAttendanceScan({
            employee: qrUser,
            scanType,
            source: "ADMIN_EMPLOYEE_QR",
            scannedBy: req.admin.username || "Admin",
            qrVersion,
            notifyWhatsApp: false,
        });

        emitRealtimeToAdmins("attendanceUpdated", {
            message: result.message,
            attendance: result.attendance,
            username: result.attendance.username || result.identity.username || "-",
            scanType,
            source: "ADMIN_EMPLOYEE_QR",
            createdAt: new Date(),
        });

        emitRealtimeToEmployee(
            [result.attendance.userId, result.attendance.email, result.attendance.username],
            "myAttendanceUpdated", {
                message: result.message,
                attendance: result.attendance,
                scanType,
                source: "ADMIN_EMPLOYEE_QR",
                createdAt: new Date(),
            }
        );

        await createAuditLog(req, {
            category: "Attendance",
            action: `SCAN_${scanType}`,
            description: `${result.message} for ${result.identity.username || result.identity.name || result.identity.email || result.employeeUserId}`,
            targetType: "Attendance",
            targetId: result.attendance._id,
            targetName: result.identity.username || result.identity.name || result.identity.email || result.employeeUserId,
            metadata: {
                scanType,
                userId: result.employeeUserId,
                date: result.attendance.date,
                source: "ADMIN_EMPLOYEE_QR",
            },
        });

        res.status(201).json({
            success: true,
            message: result.message,
            username: result.attendance.username || result.identity.username,
            data: result.attendance,
        });
    } catch (error) {
        console.error("Admin employee QR scan error:", error);
        res.status(error.statusCode || 500).json({
            success: false,
            message: error.statusCode ? error.message : "Failed to save attendance",
            error: error.message,
        });
    }
});

// ===========================
// WHATSAPP ATTENDANCE IMPORT
// Admin can paste WhatsApp group messages and update attendance
// ===========================

const normalizeImportAction = (actionText = "") => {
    const action = String(actionText || "")
        .toLowerCase()
        .replace(/[^a-z\s]/g, " ")
        .replace(/\s+/g, " ")
        .trim();

    if (!action) return null;

    if (/\b(entry|in|check in|start|duty in)\b/.test(action) && !/break/.test(action)) {
        return "ENTRY";
    }

    if (/\b(break out|breakout|lunch out|tea out)\b/.test(action)) {
        return "BREAK_OUT";
    }

    if (/\b(break in|breakin|lunch in|tea in)\b/.test(action)) {
        return "BREAK_IN";
    }

    if (/\b(out without break|out no break|without break out|no break out)\b/.test(action)) {
        return "OUT_WITHOUT_BREAK";
    }

    if (/\b(last out|check out|checkout|out|duty out|finish|end)\b/.test(action) && !/break/.test(action)) {
        return "OUT";
    }

    return null;
};

const parseImportDate = (dateText = "", fallbackDate = "") => {
    const fallback = String(fallbackDate || new Date().toISOString().slice(0, 10));
    const value = String(dateText || "").trim();

    if (!value) return fallback;

    if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
        return value;
    }

    const parts = value.split(/[\/\-.]/).map((part) => part.trim()).filter(Boolean);

    if (parts.length < 2) return fallback;

    const day = Number(parts[0]);
    const month = Number(parts[1]);
    let year = parts[2] ? Number(parts[2]) : new Date().getFullYear();

    if (year < 100) year += 2000;

    if (!day || !month || !year || day < 1 || day > 31 || month < 1 || month > 12) {
        return fallback;
    }

    return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
};

const buildDateTimeFromParts = (dateValue, timeValue) => {
    const date = String(dateValue || new Date().toISOString().slice(0, 10));
    const time = String(timeValue || "").trim();

    if (!/^\d{4}-\d{2}-\d{2}$/.test(date) || !/^\d{1,2}:\d{2}$/.test(time)) {
        return null;
    }

    const [hourText, minuteText] = time.split(":");
    const hour = Number(hourText);
    const minute = Number(minuteText);

    if (hour < 0 || hour > 23 || minute < 0 || minute > 59) {
        return null;
    }

    return new Date(`${date}T${String(hour).padStart(2, "0")}:${String(minute).padStart(2, "0")}:00`);
};

const parseWhatsAppAttendanceLine = (line = "", fallbackDate = "") => {
    const rawLine = String(line || "").trim();

    if (!rawLine) return null;

    let match = rawLine.match(/^\[?(\d{1,2}[\/\-.]\d{1,2}(?:[\/\-.]\d{2,4})?),\s*(\d{1,2}:\d{2})\]?\s*([^:]+):\s*(.+)$/i);

    if (match) {
        const [, dateText, timeText, nameText, actionText] = match;
        return {
            rawLine,
            date: parseImportDate(dateText, fallbackDate),
            time: timeText,
            employeeName: nameText.trim(),
            scanType: normalizeImportAction(actionText),
            actionText: actionText.trim(),
        };
    }

    match = rawLine.match(/^(.+?)\s+(entry|in|check\s*in|break\s*out|breakout|break\s*in|breakin|out\s*without\s*break|out\s*no\s*break|last\s*out|check\s*out|checkout|out|finish|end)\s+(\d{1,2}:\d{2})(?:\s+(\d{1,2}[\/\-.]\d{1,2}(?:[\/\-.]\d{2,4})?|\d{4}-\d{2}-\d{2}))?$/i);

    if (match) {
        const [, nameText, actionText, timeText, dateText] = match;
        return {
            rawLine,
            date: parseImportDate(dateText, fallbackDate),
            time: timeText,
            employeeName: nameText.trim(),
            scanType: normalizeImportAction(actionText),
            actionText: actionText.trim(),
        };
    }

    match = rawLine.match(/^(.+?)\s+(\d{1,2}:\d{2})\s+(entry|in|check\s*in|break\s*out|breakout|break\s*in|breakin|out\s*without\s*break|out\s*no\s*break|last\s*out|check\s*out|checkout|out|finish|end)(?:\s+(\d{1,2}[\/\-.]\d{1,2}(?:[\/\-.]\d{2,4})?|\d{4}-\d{2}-\d{2}))?$/i);

    if (match) {
        const [, nameText, timeText, actionText, dateText] = match;
        return {
            rawLine,
            date: parseImportDate(dateText, fallbackDate),
            time: timeText,
            employeeName: nameText.trim(),
            scanType: normalizeImportAction(actionText),
            actionText: actionText.trim(),
        };
    }

    return {
        rawLine,
        error: "Unsupported format",
    };
};

const escapeRegexText = (value = "") => {
    return String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
};

const findEmployeeForImport = async(employeeName = "") => {
    const name = String(employeeName || "").trim();

    if (!name) return null;

    const exactRegex = new RegExp(`^${escapeRegexText(name)}$`, "i");
    const startsWithRegex = new RegExp(`^${escapeRegexText(name)}\\b`, "i");

    return User.findOne({
        $or: [
            { username: exactRegex },
            { email: exactRegex },
            { mobile: exactRegex },
            { username: startsWithRegex },
        ],
    }).select("_id username email mobile");
};

const recalculateAttendanceTotals = (attendance, referenceTime = new Date()) => {
    return recalculateAttendanceFromHistory(attendance, referenceTime);
};


app.post("/api/attendance/import-whatsapp", verifyAdmin, async(req, res) => {
    try {
        const text = String(req.body.text || "").trim();
        const fallbackDate = String(req.body.date || new Date().toISOString().slice(0, 10)).trim();

        if (!text) {
            return res.status(400).json({
                success: false,
                message: "Please paste WhatsApp attendance messages",
            });
        }

        const lines = text
            .split(/\r?\n/)
            .map((line) => line.trim())
            .filter(Boolean);

        if (lines.length === 0) {
            return res.status(400).json({
                success: false,
                message: "No valid lines found",
            });
        }

        const imported = [];
        const skipped = [];

        for (const line of lines) {
            const parsed = parseWhatsAppAttendanceLine(line, fallbackDate);

            if (!parsed || parsed.error) {
                skipped.push({ line, reason: parsed?.error || "Unable to read line" });
                continue;
            }

            if (!parsed.scanType) {
                skipped.push({ line, reason: `Unknown action: ${parsed.actionText || ""}` });
                continue;
            }

            const scanDateTime = buildDateTimeFromParts(parsed.date, parsed.time);

            if (!scanDateTime) {
                skipped.push({ line, reason: "Invalid date or time" });
                continue;
            }

            const employee = await findEmployeeForImport(parsed.employeeName);

            if (!employee) {
                skipped.push({ line, reason: `Employee not found: ${parsed.employeeName}` });
                continue;
            }

            const identity = getEmployeeIdentity(employee);
            const employeeUserId = String(employee._id);

            let attendance = await Attendance.findOne({
                userId: employeeUserId,
                date: parsed.date,
            });

            if (!attendance) {
                attendance = new Attendance({
                    userId: employeeUserId,
                    date: parsed.date,
                });
            }

            attendance.userId = employeeUserId;
            attendance.name = identity.name;
            attendance.username = identity.username;
            attendance.email = identity.email;
            attendance.mobile = identity.mobile;

            const importedScanType =
                parsed.scanType === "OUT_WITHOUT_BREAK"
                    ? "OUT"
                    : parsed.scanType;

            if (!Array.isArray(attendance.scanHistory)) {
                attendance.scanHistory = [];
            }

            attendance.scanHistory.push({
                scanType: importedScanType,
                scannedAt: scanDateTime,
                source: "WHATSAPP_IMPORT",
                scannedBy: req.admin?.username || req.user?.username || "WhatsApp Import",
                qrVersion: "",
                whatsappStatus: "skipped",
                whatsappError: "",
            });

            recalculateAttendanceTotals(attendance, scanDateTime);
            await attendance.save();

            imported.push({
                line,
                employee: attendance.username || attendance.name || "-",
                date: attendance.date,
                time: parsed.time,
                scanType: parsed.scanType,
                noBreak: parsed.scanType === "OUT_WITHOUT_BREAK",
                attendanceId: attendance._id,
            });
        }

        if (imported.length > 0) {
            emitRealtimeToAdmins("attendanceImported", {
                message: `${imported.length} WhatsApp attendance line(s) imported`,
                imported,
                skipped,
                createdAt: new Date(),
            });

            await createAuditLog(req, {
                category: "Attendance",
                action: "IMPORT_WHATSAPP_ATTENDANCE",
                description: `Imported ${imported.length} WhatsApp attendance line(s). Skipped ${skipped.length}.`,
                targetType: "Attendance",
                targetName: "WhatsApp Import",
                metadata: {
                    importedCount: imported.length,
                    skippedCount: skipped.length,
                    fallbackDate,
                },
            });
        }

        res.json({
            success: true,
            message: `Imported ${imported.length} line(s). Skipped ${skipped.length} line(s).`,
            data: {
                imported,
                skipped,
            },
        });
    } catch (error) {
        console.error("WhatsApp attendance import error:", error);
        res.status(500).json({
            success: false,
            message: "Failed to import WhatsApp attendance",
            error: error.message,
        });
    }
});

app.post("/api/my/attendance/import-whatsapp", verifyToken, async(req, res) => {
    try {
        const text = String(req.body.text || "").trim();
        const fallbackDate = String(req.body.date || new Date().toISOString().slice(0, 10)).trim();

        if (!text) {
            return res.status(400).json({
                success: false,
                message: "Please paste your WhatsApp attendance messages",
            });
        }

        const employee = await User.findById(req.user.id).select("_id username email mobile");

        if (!employee) {
            return res.status(404).json({
                success: false,
                message: "Employee not found. Please login again.",
            });
        }

        const lines = text
            .split(/\r?\n/)
            .map((line) => line.trim())
            .filter(Boolean);

        if (lines.length === 0) {
            return res.status(400).json({
                success: false,
                message: "No valid WhatsApp lines found",
            });
        }

        const imported = [];
        const skipped = [];
        const identity = getEmployeeIdentity(employee);
        const employeeUserId = String(employee._id);

        for (const line of lines) {
            const parsed = parseWhatsAppAttendanceLine(line, fallbackDate);

            if (!parsed || parsed.error) {
                skipped.push({ line, reason: parsed?.error || "Unable to read line" });
                continue;
            }

            if (!parsed.scanType) {
                skipped.push({ line, reason: `Unknown action: ${parsed.actionText || ""}` });
                continue;
            }

            const scanDateTime = buildDateTimeFromParts(parsed.date, parsed.time);

            if (!scanDateTime) {
                skipped.push({ line, reason: "Invalid date or time" });
                continue;
            }

            let attendance = await Attendance.findOne({
