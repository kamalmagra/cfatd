            attendance.userId = employeeUserId;
            attendance.name = identity.name;
            attendance.username = identity.username;
            attendance.email = identity.email;
            attendance.mobile = identity.mobile;

            const importedScanType =
                parsed.scanType === "OUT_WITHOUT_BREAK"
                    ? "OUT"
                    : parsed.scanType;

            if (!Array.isArray(attendance.scanHistory)) {
                attendance.scanHistory = [];
            }

            attendance.scanHistory.push({
                scanType: importedScanType,
                scannedAt: scanDateTime,
                source: "WHATSAPP_IMPORT",
                scannedBy: req.admin?.username || req.user?.username || "WhatsApp Import",
                qrVersion: "",
                whatsappStatus: "skipped",
                whatsappError: "",
            });

            recalculateAttendanceTotals(attendance, scanDateTime);
            await attendance.save();

            imported.push({
                line,
                date: attendance.date,
                time: parsed.time,
                scanType: parsed.scanType,
                noBreak: parsed.scanType === "OUT_WITHOUT_BREAK",
                attendanceId: attendance._id,
            });
        }

        if (imported.length > 0) {
            emitRealtimeToAdmins("attendanceImported", {
                message: `${identity.username || identity.name || "Employee"} imported ${imported.length} WhatsApp attendance line(s)`,
                imported,
                skipped,
                employee: {
                    _id: employee._id,
                    username: employee.username,
                    email: employee.email,
                },
                createdAt: new Date(),
            });

            emitRealtimeToEmployee([employee._id, employee.email, employee.username], "myAttendanceUpdated", {
                message: "Your WhatsApp attendance was saved",
                imported,
                skipped,
                createdAt: new Date(),
            });
        }

        res.json({
            success: true,
            message: `Saved ${imported.length} line(s). Skipped ${skipped.length} line(s).`,
            data: {
                imported,
                skipped,
            },
        });
    } catch (error) {
        console.error("Employee WhatsApp attendance import error:", error);
        res.status(500).json({
            success: false,
            message: "Failed to save WhatsApp attendance",
            error: error.message,
        });
    }
});

app.put("/api/scan/attendance/:id", verifyAdmin, async(req, res) => {
    try {
        const {
            entryTime,
            breakOutTime,
            breakInTime,
            lastOutTime,
        } = req.body;

        const attendance = await Attendance.findById(req.params.id);

        if (!attendance) {
            return res.status(404).json({
                success: false,
                message: "Attendance record not found",
            });
        }

        let history = Array.isArray(attendance.scanHistory)
            ? attendance.scanHistory.map((item) =>
                  typeof item.toObject === "function"
                      ? item.toObject()
                      : { ...item }
              )
            : [];

        if (history.length === 0) {
            history = buildLegacyAttendanceEvents(attendance).map((item) => ({
                ...item,
                source: "ADMIN_EDIT",
                scannedBy: req.admin.username || "Admin",
                qrVersion: "",
                whatsappStatus: "skipped",
                whatsappError: "",
            }));
        }

        const updateHistoryEvent = (
            scanType,
            value,
            useFirstMatch = false
        ) => {
            const matchingIndexes = history
                .map((item, index) =>
                    item.scanType === scanType ? index : -1
                )
                .filter((index) => index >= 0);

            const targetIndex =
                matchingIndexes.length === 0
                    ? -1
                    : useFirstMatch
                    ? matchingIndexes[0]
                    : matchingIndexes[matchingIndexes.length - 1];

            if (!value) {
                if (targetIndex >= 0) {
                    history.splice(targetIndex, 1);
                }
                return;
            }

            const parsedDate = new Date(value);

            if (Number.isNaN(parsedDate.getTime())) {
                throw attendanceStateError(
                    `Invalid ${scanType} date/time value.`
                );
            }

            const nextEvent = {
                scanType,
                scannedAt: parsedDate,
                source: "ADMIN_EDIT",
                scannedBy: req.admin.username || "Admin",
                qrVersion: "",
                whatsappStatus: "skipped",
                whatsappError: "",
            };

            if (targetIndex >= 0) {
                history[targetIndex] = {
                    ...history[targetIndex],
                    ...nextEvent,
                };
            } else {
                history.push(nextEvent);
            }
        };

        updateHistoryEvent("ENTRY", entryTime, true);
        updateHistoryEvent("BREAK_OUT", breakOutTime, false);
        updateHistoryEvent("BREAK_IN", breakInTime, false);
        updateHistoryEvent("OUT", lastOutTime, false);

        attendance.scanHistory = history;

        const latestEventTime = history.reduce((latest, item) => {
            const itemDate = new Date(item.scannedAt);
            return !Number.isNaN(itemDate.getTime()) && itemDate > latest
                ? itemDate
                : latest;
        }, new Date(0));

        recalculateAttendanceFromHistory(
            attendance,
            latestEventTime.getTime() > 0 ? latestEventTime : new Date()
        );

        await attendance.save();

        emitRealtimeToAdmins("attendanceEdited", {
            message: "Attendance updated successfully",
            attendance,
            username:
                attendance.username ||
                attendance.name ||
                attendance.email ||
                "-",
            createdAt: new Date(),
        });

        emitRealtimeToEmployee(
            [
                attendance.userId,
                attendance.email,
                attendance.username,
            ],
            "myAttendanceUpdated",
            {
                message: "Your attendance was updated by admin",
                attendance,
                createdAt: new Date(),
            }
        );

        await createAuditLog(req, {
            category: "Attendance",
            action: "UPDATE_ATTENDANCE",
            description: `Updated attendance for ${
                attendance.username ||
                attendance.name ||
                attendance.email ||
                attendance.userId
            } on ${attendance.date || "selected date"}`,
            targetType: "Attendance",
            targetId: attendance._id,
            targetName:
                attendance.username ||
                attendance.name ||
                attendance.email ||
                String(attendance.userId),
            metadata: {
                date: attendance.date,
                entryTime,
                breakOutTime,
                breakInTime,
                lastOutTime,
            },
        });

        res.json({
            success: true,
            message: "Attendance updated successfully",
            data: attendance,
        });
    } catch (error) {
        res.status(error.statusCode || 500).json({
            success: false,
            message:
                error.statusCode
                    ? error.message
                    : "Failed to update attendance",
            error: error.message,
        });
    }
});


app.get("/api/scan/attendance", verifyAdmin, async(req, res) => {
    try {
        const page = Math.max(parseInt(req.query.page, 10) || 1, 1);
        const limitValue = parseInt(req.query.limit, 10) || 10;
        const limit = Math.min(Math.max(limitValue, 5), 100);
        const skip = (page - 1) * limit;

        const { startDate, endDate, search } = req.query;

        const filter = {};

        if (startDate || endDate) {
            filter.createdAt = {};

            if (startDate) {
                const start = new Date(startDate);
                start.setHours(0, 0, 0, 0);
                filter.createdAt.$gte = start;
            }

            if (endDate) {
                const end = new Date(endDate);
                end.setHours(23, 59, 59, 999);
                filter.createdAt.$lte = end;
            }
        }

        if (search && String(search).trim()) {
            const safeSearch = String(search).trim().replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
            const regex = new RegExp(safeSearch, "i");

            filter.$or = [
                { name: regex },
                { username: regex },
                { email: regex },
                { mobile: regex },
                { date: regex },
            ];
        }

        const [attendance, totalRecords] = await Promise.all([
            Attendance.find(filter)
            .sort({ createdAt: -1 })
            .skip(skip)
            .limit(limit),
            Attendance.countDocuments(filter),
        ]);

        const enrichedAttendance = await enrichAttendanceRecords(attendance);

        const totalPages = Math.max(Math.ceil(totalRecords / limit), 1);

        res.json({
            success: true,
            data: enrichedAttendance,
            pagination: {
                page,
                limit,
                totalRecords,
                totalPages,
                hasPrevPage: page > 1,
                hasNextPage: page < totalPages,
            },
            filters: {
                startDate: startDate || "",
                endDate: endDate || "",
                search: search || "",
            },
        });
    } catch (error) {
        res.status(500).json({
            success: false,
            message: "Failed to fetch attendance",
            error: error.message,
        });
    }
});

