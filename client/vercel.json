{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cfatd-backend.onrender.com/api/:path*"
    },
    {
      "source": "/login",
      "destination": "https://cfatd-backend.onrender.com/login"
    },
    {
      "source": "/register",
      "destination": "https://cfatd-backend.onrender.com/register"
    },
    {
      "source": "/admin-login",
      "destination": "https://cfatd-backend.onrender.com/admin-login"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
